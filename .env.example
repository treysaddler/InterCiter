# Docker Compose settings for the InterCiter stack (docker-compose.yml).
# Copy to `.env` and adjust. `.env` is gitignored — never commit real secrets.

# --- PostgreSQL (system of record) ---
POSTGRES_USER=interciter
# CHANGE THIS before exposing the stack anywhere.
POSTGRES_PASSWORD=interciter
POSTGRES_DB=interciter

# --- API ---
# uvicorn worker processes per backend container (vertical scaling).
UVICORN_WORKERS=2
# Keep false for the plain-http local stack; set true behind TLS in production.
SESSION_COOKIE_SECURE=false

# --- Web ---
# Host port for the nginx-served SPA (http://localhost:WEB_PORT).
WEB_PORT=8080

# --- Semantic Scholar ---
# Required for the bulk Datasets API; raises Graph API rate limits too.
# Get one at https://www.semanticscholar.org/product/api#api-key-form
S2_API_KEY=
