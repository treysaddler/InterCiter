# InterCiter environment template.
#
# Copy this file to `.env` (in backend/, the working directory for the CLI and server)
# and fill in real values. `.env` is gitignored — never commit real secrets. Settings
# are read by interciter/config.py via the INTERCITER_ prefix.

# --- Semantic Scholar ---
# Academic Graph works unauthenticated (shared pool); a key raises limits and is
# REQUIRED for the bulk Datasets API. Received privately by email — keep it secret.
INTERCITER_S2_API_KEY=

# --- NCBI / PMC (evaluation gold set fetching) ---
# NCBI asks that requests identify a contact email; an API key raises the rate limit.
INTERCITER_NCBI_EMAIL=
# INTERCITER_NCBI_API_KEY=

# --- LLM extraction (any OpenAI-compatible endpoint) ---
# NIEHS LiteLLM proxy (live) or a Biowulf-hosted server. Leave base_url empty to use
# only the deterministic stub / offline batch mode. --model on the CLI overrides the
# default model per run (for frontier-vs-local comparison).
INTERCITER_LLM_BASE_URL=
INTERCITER_LLM_API_KEY=
INTERCITER_LLM_MODEL=gpt-4o
# INTERCITER_LLM_PROVIDER=niehs-litellm

# --- Database (optional; defaults to a local SQLite file) ---
# INTERCITER_DATABASE_URL=sqlite:///./interciter.db

# --- Browser sessions (BFF cookie for the web UI — docs/ui-design.md §11) ---
# secure=true means cookies are only sent over TLS. Keep TRUE in production; set FALSE
# for local http dev (the Vite dev proxy talks to the backend over http on localhost).
# INTERCITER_SESSION_COOKIE_SECURE=false
# NIST SP 800-63B session timeouts (minutes idle / hours absolute).
# INTERCITER_SESSION_IDLE_TIMEOUT_MINUTES=30
# INTERCITER_SESSION_ABSOLUTE_LIFETIME_HOURS=12
